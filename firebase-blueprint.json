{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A group or category for sorting meetings (e.g. personal, startup-web)",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique project identifier"
        },
        "name": {
          "type": "string",
          "description": "Display name of the project"
        },
        "color": {
          "type": "string",
          "description": "Accent color representing the project"
        },
        "description": {
          "type": "string",
          "description": "Optional details about the project"
        },
        "userId": {
          "type": "string",
          "description": "Owner userId of this project"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": [
        "id",
        "name",
        "color",
        "userId"
      ]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "An audio recording or imported log file with complete AI-generated analytical metadata",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique meeting identifier"
        },
        "title": {
          "type": "string",
          "description": "Custom or AI summarized header"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Start timestamp of the session"
        },
        "durationSec": {
          "type": "integer",
          "description": "Length of the audio recording in seconds"
        },
        "project": {
          "type": "string",
          "description": "Display name of the parent sorting project"
        },
        "summary": {
          "type": "string",
          "description": "Detailed markdown or clean textual analytical summary"
        },
        "snapshot": {
          "type": "string",
          "description": "Very short executive description of the meeting"
        },
        "userId": {
          "type": "string",
          "description": "Owner userId of this meeting data"
        },
        "classification": {
          "type": "object",
          "description": "Primary and secondary categories"
        },
        "participantsInfo": {
          "type": "array",
          "description": "Calculated team share metrics"
        },
        "decisions": {
          "type": "array",
          "description": "Team agreement outcomes"
        },
        "checklist": {
          "type": "array",
          "description": "A list of strings representing checklist goals"
        },
        "openQuestions": {
          "type": "array",
          "description": "Unresolved concerns"
        },
        "topics": {
          "type": "array",
          "description": "Main conversation headers"
        },
        "actionItems": {
          "type": "array",
          "description": "Assigned task objectives"
        },
        "transcript": {
          "type": "array",
          "description": "Complete verbatim text split by speakers with timing offsets"
        },
        "tags": {
          "type": "array",
          "description": "User categorizing attributes"
        },
        "insights": {
          "type": "array",
          "description": "Subtle interpersonal warnings or recommendations"
        },
        "nextTouchpoints": {
          "type": "array",
          "description": "Future appointments or actions"
        },
        "memoryUpdates": {
          "type": "array",
          "description": "Continuous personal profile log update entries"
        },
        "audioUrl": {
          "type": "string",
          "description": "Optional binary playback source"
        },
        "isPending": {
          "type": "boolean",
          "description": "Processing status"
        },
        "isFailed": {
          "type": "boolean",
          "description": "Wether processing has hit an error state"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Time the document sync was initiated"
        }
      },
      "required": [
        "id",
        "title",
        "date",
        "durationSec",
        "project",
        "userId"
      ]
    }
  },
  "firestore": {
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "Collections of customizable sorting folders representing customer projects"
    },
    "/users/{userId}/meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Audio logs containing analytical summaries, transcripts, and actions"
    }
  }
}
